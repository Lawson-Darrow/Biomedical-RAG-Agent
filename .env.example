# Copy to .env and fill in. .env is gitignored.

# --- LLMGateway (OSS, OpenAI-compatible) — all model traffic routes here ---
# Frontier (Claude, GPT) and open (DeepSeek, Kimi/Moonshot, Qwen/Alibaba) are all
# reached as model IDs through this one endpoint. Add your provider keys via BYOK
# in the LLMGateway dashboard (https://llmgateway.io) — the app only needs the
# gateway key below. Exact model IDs get pinned from the /models catalog at impl time.
LLMGATEWAY_API_KEY=
LLMGATEWAY_BASE_URL=https://api.llmgateway.io/v1

# --- Vector store (pgvector) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/biomed_rag

# --- Retrieval / embeddings ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RETRIEVAL_TOP_K=8
