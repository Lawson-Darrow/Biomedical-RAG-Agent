# Copy to .env and fill in. .env is gitignored.

# --- Frontier model providers (at least one for the frontier arm) ---
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# --- Open-weights endpoint (OpenAI-compatible: Ollama, vLLM, TogetherAI, etc.) ---
# Default open model is Qwen2.5-7B served behind an OpenAI-compatible API.
OPEN_MODEL_BASE_URL=http://localhost:11434/v1
OPEN_MODEL_NAME=qwen2.5:7b
OPEN_MODEL_API_KEY=ollama

# --- Vector store (pgvector) ---
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/biomed_rag

# --- Retrieval / embeddings ---
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RETRIEVAL_TOP_K=8
